# DocFlow AI 환경변수

# ── AI ──
OPENAI_API_KEY=sk-your-key-here
TAVILY_API_KEY=tvly-your-key-here

# ── 외부 API ──
BIZINFO_API_KEY=your-bizinfo-api-key   # 기업마당(bizinfo.go.kr) 오픈API 인증키

# ── 서버 ──
BACKEND_PORT=8000
FRONTEND_PORT=3000
DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
BACKEND_URL=http://localhost:8000      # 파일 다운로드 절대 URL. Railway 배포 시 Railway URL로 변경

# ── 파일 저장 ──
OUTPUT_DIR=./outputs
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
FILE_TTL_HOURS=1

# ── 모델 ──
DEFAULT_MODEL=gpt-4o
FAST_MODEL=gpt-4o-mini

# ── n8n ──
N8N_API_KEY=your-internal-api-key
N8N_PASSWORD=your-n8n-admin-password

# ── Supabase ──
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key...

# ── 인증 ──
REQUIRE_AUTH=false   # 개발 중 false, 운영 시 true
