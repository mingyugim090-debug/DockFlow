# DocFlow AI 환경변수 설정
# 이 파일을 .env로 복사하고 실제 값으로 채우세요
# cp .env.example .env

# =====================
# AI API 키 (필수)
# =====================
ANTHROPIC_API_KEY=sk-ant-your-key-here
TAVILY_API_KEY=tvly-your-key-here

# =====================
# 내부 서비스 인증
# =====================
# n8n이 DocFlow API 호출 시 사용하는 키
N8N_API_KEY=change-me-to-random-string-32chars

# n8n 관리자 패스워드
N8N_PASSWORD=change-me-to-secure-password

# =====================
# 서버 설정
# =====================
BACKEND_PORT=8000
FRONTEND_PORT=3000
N8N_PORT=5678
DEBUG=false

# =====================
# 파일 저장
# =====================
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs
MAX_FILE_SIZE_MB=50
FILE_TTL_HOURS=1

# =====================
# 데이터베이스 (Phase 3~4)
# =====================
# DATABASE_URL=postgresql://user:pass@localhost:5432/docflow
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-anon-key

# =====================
# 클라우드 스토리지 (Phase 3~4)
# =====================
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_ACCESS_KEY=your-r2-access-key
# R2_SECRET_KEY=your-r2-secret-key
# R2_BUCKET_NAME=docflow-outputs

# =====================
# 알림 (선택)
# =====================
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
